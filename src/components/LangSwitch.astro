---
import { localizedPath, useTranslations, type Locale } from '@/i18n/utils';

interface Props {
  locale: Locale;
  currentPath: string;
  variant?: 'nav' | 'mobile';
}

const { locale, currentPath, variant = 'nav' } = Astro.props;
const t = useTranslations(locale);

const entries: Array<{ code: Locale; label: string; hreflang: string }> = [
  { code: 'en', label: 'EN', hreflang: 'en' },
  { code: 'it', label: 'IT', hreflang: 'it' },
  { code: 'ua', label: 'UA', hreflang: 'uk' },
  { code: 'ru', label: 'RU', hreflang: 'ru' },
];
---

<div class:list={['lang-switch', `lang-switch--${variant}`]} role="group" aria-label={t('lang.label')}>
  {entries.map((entry) => (
    <a
      href={localizedPath(currentPath, entry.code)}
      hreflang={entry.hreflang}
      aria-current={locale === entry.code ? 'true' : undefined}
      class:list={['lang-switch__opt', { active: locale === entry.code }]}
    >
      {entry.label}
    </a>
  ))}
</div>
