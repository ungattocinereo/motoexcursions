---
import { Icon } from 'astro-icon/components';
import { formatDate, useTranslations, type Locale } from '@/i18n/utils';

interface Review {
  author: string;
  rating: number;
  text: string;
  date: string;
  source: string;
}

interface Props {
  reviews: Review[];
  locale: Locale;
  hideHeading?: boolean;
}

const { reviews, locale, hideHeading = false } = Astro.props;
const t = useTranslations(locale);
---

<div class="review-list">
  {!hideHeading && (
    <div class="section-head" style="margin-bottom: 0.5rem;">
      <h2 style="font-size: 1.3rem;">{t('reviews.heading')}</h2>
    </div>
  )}
  {reviews.length === 0 ? (
    <p class="review-list__empty">{t('reviews.empty')}</p>
  ) : (
    <div class="review-list__items">
      {reviews.map((review) => {
        const safeRating = Math.max(1, Math.min(5, review.rating));
        const isFacebook = review.source === 'facebook';
        return (
          <article class="review-card">
            <header class="review-card__head">
              <span class="review-card__avatar" aria-hidden="true">
                {review.author.trim().charAt(0).toUpperCase()}
              </span>
              <div class="review-card__who">
                <strong>{review.author}</strong>
                <span class="review-card__meta">
                  <span>{formatDate(review.date, locale)}</span>
                  {isFacebook && (
                    <span class="review-card__source" title={t('reviews.sourceFacebook')}>
                      <Icon name="lucide:facebook" aria-hidden="true" />
                      <span>{t('reviews.sourceFacebook')}</span>
                    </span>
                  )}
                </span>
              </div>
              <div class="review-card__stars" aria-label={`${safeRating} / 5`}>
                {Array.from({ length: safeRating }).map(() => (
                  <Icon name="lucide:star" aria-hidden="true" />
                ))}
              </div>
            </header>
            <p class="review-card__text">{review.text}</p>
          </article>
        );
      })}
    </div>
  )}
</div>
