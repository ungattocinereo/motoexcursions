---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { useTranslations, type Locale } from '@/i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<BaseLayout title={t('terms.seoTitle')} description={t('terms.seoDescription')} locale={locale}>
  <section class="surface-card reveal" data-reveal style="margin-top: 1rem; padding: 1rem;">
    <h1 style="margin-top: 0;">{t('terms.heading')}</h1>
    <p>{t('terms.p1')}</p>
    <ul>
      <li>{t('terms.b1')}</li>
      <li>{t('terms.b2')}</li>
      <li>{t('terms.b3')}</li>
    </ul>
  </section>
</BaseLayout>
