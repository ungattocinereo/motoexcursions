---
import BaseLayout from '@/layouts/BaseLayout.astro';
import LeadForm from '@/components/LeadForm.astro';
import { useTranslations, type Locale } from '@/i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<BaseLayout title={t('contact.seoTitle')} description={t('contact.seoDescription')} locale={locale}>
  <section class="surface-card reveal" data-reveal style="margin-top: 1rem; padding: 1.1rem;">
    <p class="kicker" style="margin: 0;">{t('contact.kicker')}</p>
    <h1 style="margin: 0.4rem 0 0.5rem;">{t('contact.heading')}</h1>
    <p style="margin: 0 0 0.9rem; color: var(--muted);">{t('contact.subtitle')}</p>
    <LeadForm
      tourSlug="contact"
      tourTitle={t('contact.generalTitle')}
      pageUrl={Astro.url.href}
      locale={locale}
      buttonLabel={t('form.submitContact')}
      showHeading={false}
    />
  </section>
</BaseLayout>
