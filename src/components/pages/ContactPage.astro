---
import { Icon } from 'astro-icon/components';
import BaseLayout from '@/layouts/BaseLayout.astro';
import LeadForm from '@/components/LeadForm.astro';
import SocialLinks from '@/components/SocialLinks.astro';
import { getTours, tourSlug } from '@/lib/tours';
import { htmlLang, localizedPath, useTranslations, type Locale } from '@/i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const allTours = await getTours(locale);
const tourOptions = allTours.map((tour) => ({
  slug: tourSlug(tour),
  title: tour.data.title,
}));

const waPhone = '393347200808';
const telPhone = '+393347200808';
const displayPhone = '+39 334 7200 808';
const waHref = `https://wa.me/${waPhone}?text=${encodeURIComponent(t('wa.prefill'))}`;

const site = Astro.site ?? new URL('https://motoexcursions.it');
const contactUrl = new URL(localizedPath('/contact/', locale), site).toString();
const orgId = `${site.toString()}#organization`;

const breadcrumbs = [
  { name: t('nav.home'), url: localizedPath('/', locale) },
  { name: t('nav.contact'), url: localizedPath('/contact/', locale) },
];

const contactLd = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  '@id': `${contactUrl}#webpage`,
  url: contactUrl,
  name: t('contact.seoTitle'),
  description: t('contact.seoDescription'),
  inLanguage: htmlLang[locale],
  isPartOf: { '@id': `${site.toString()}#website` },
  about: { '@id': orgId },
  mainEntity: {
    '@type': 'Organization',
    '@id': orgId,
    contactPoint: {
      '@type': 'ContactPoint',
      contactType: 'customer service',
      telephone: telPhone,
      email: 'info@motoexcursions.it',
      availableLanguage: ['English', 'Italian', 'Ukrainian', 'Russian'],
      hoursAvailable: {
        '@type': 'OpeningHoursSpecification',
        dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'],
        opens: '08:00',
        closes: '22:00',
      },
    },
  },
};
---

<BaseLayout
  title={t('contact.seoTitle')}
  description={t('contact.seoDescription')}
  locale={locale}
  breadcrumbs={breadcrumbs}
  jsonLd={contactLd}
>
  <div class="contact-layout">
    <!-- ── Left: About the guide ── -->
    <article class="contact-about reveal" data-reveal>
      <figure class="contact-about__portrait">
        <img src="/images/dima-about.webp" alt={t('about.imageAlt')} loading="eager" decoding="async" />
        <figcaption class="contact-about__caption">
          <span class="contact-about__caption-name">{t('hero.cardName')}</span>
          <span class="contact-about__caption-role">{t('hero.cardRole')} · Napoli</span>
        </figcaption>
      </figure>

      <div class="contact-about__body">
        <span class="contact-about__kicker">{t('about.kicker')}</span>
        <h1 class="contact-about__heading">{t('about.heading')}</h1>
        <div class="contact-about__rule" aria-hidden="true"></div>
        <p>{t('about.p1')}</p>
        <p>{t('about.p2')}</p>
        <p>{t('about.p3')}</p>
        <p>{t('about.p4')}</p>
      </div>
    </article>

    <!-- ── Right: Actionable contact ── -->
    <aside class="contact-aside">
      <section class="contact-card contact-card--channels reveal" data-reveal data-delay="1">
        <p class="contact-card__kicker">{t('contact.kicker')}</p>
        <h2 class="contact-card__title">{t('contact.heading')}</h2>
        <p class="contact-card__lead">{t('contact.subtitle')}</p>

        <p class="contact-sla">
          <Icon name="lucide:clock" aria-hidden="true" />
          <span>{t('contact.responseTime')}</span>
        </p>

        <div class="contact-channels">
          <a
            class="contact-channel contact-channel--wa"
            href={waHref}
            target="_blank"
            rel="noopener noreferrer"
          >
            <Icon name="lucide:message-circle" aria-hidden="true" />
            <span>{t('tourDetail.whatsappCta')}</span>
          </a>
          <a class="contact-channel contact-channel--call" href={`tel:${telPhone}`}>
            <Icon name="lucide:phone" aria-hidden="true" />
            <span>{displayPhone}</span>
          </a>
        </div>

        <p class="contact-languages">
          <Icon name="lucide:languages" aria-hidden="true" />
          <span>{t('tourDetail.languageValue')}</span>
        </p>
      </section>

      <section class="contact-card contact-card--form reveal" data-reveal data-delay="2">
        <div class="contact-card__head">
          <h3>{t('contact.formHeading')}</h3>
          <p>{t('contact.formSubtitle')}</p>
        </div>
        <LeadForm locale={locale} pageUrl={Astro.url.href} tours={tourOptions} />
      </section>

      <section class="contact-card contact-card--pickup reveal" data-reveal data-delay="3">
        <span class="contact-pickup-icon" aria-hidden="true">
          <Icon name="lucide:map-pin" />
        </span>
        <div class="contact-pickup-body">
          <h3>{t('contact.pickupTitle')}</h3>
          <p>{t('contact.pickupBody')}</p>
        </div>
      </section>
    </aside>
  </div>

  <!-- ── Bottom: Follow along ── -->
  <SocialLinks locale={locale} />
</BaseLayout>
