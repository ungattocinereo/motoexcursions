---
import { Icon } from 'astro-icon/components';
import BaseLayout from '@/layouts/BaseLayout.astro';
import LeadForm from '@/components/LeadForm.astro';
import SocialLinks from '@/components/SocialLinks.astro';
import { getTours, tourSlug } from '@/lib/tours';
import { useTranslations, type Locale } from '@/i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const allTours = await getTours(locale);
const tourOptions = allTours.map((tour) => ({
  slug: tourSlug(tour),
  title: tour.data.title,
}));

const waPhone = '393347200808';
const telPhone = '+393347200808';
const displayPhone = '+39 334 7200 808';
const waHref = `https://wa.me/${waPhone}?text=${encodeURIComponent(t('wa.prefill'))}`;
---

<BaseLayout title={t('contact.seoTitle')} description={t('contact.seoDescription')} locale={locale}>
  <section class="contact-hero surface-card reveal" data-reveal>
    <p class="kicker">{t('contact.kicker')}</p>
    <h1 class="contact-hero__title">{t('contact.heading')}</h1>
    <p class="contact-hero__subtitle">{t('contact.subtitle')}</p>

    <p class="contact-hero__sla">
      <Icon name="lucide:clock" aria-hidden="true" />
      <span>{t('contact.responseTime')}</span>
    </p>

    <div class="contact-hero__channels">
      <a
        class="contact-channel contact-channel--wa"
        href={waHref}
        target="_blank"
        rel="noopener noreferrer"
      >
        <Icon name="lucide:message-circle" aria-hidden="true" />
        <span>{t('tourDetail.whatsappCta')}</span>
      </a>
      <a class="contact-channel contact-channel--call" href={`tel:${telPhone}`}>
        <Icon name="lucide:phone" aria-hidden="true" />
        <span>{displayPhone}</span>
      </a>
    </div>

    <p class="contact-hero__languages">
      <Icon name="lucide:languages" aria-hidden="true" />
      <span>{t('tourDetail.languageValue')}</span>
    </p>
  </section>

  <section class="surface-card reveal contact-section" data-reveal>
    <div class="section-head" style="margin-bottom: 0.75rem;">
      <h2 style="margin: 0 0 0.25rem;">{t('contact.formHeading')}</h2>
      <p style="margin: 0; color: var(--muted);">{t('contact.formSubtitle')}</p>
    </div>
    <LeadForm locale={locale} pageUrl={Astro.url.href} tours={tourOptions} />
  </section>

  <section class="surface-card reveal contact-section pickup-card" data-reveal>
    <span class="pickup-card__icon" aria-hidden="true">
      <Icon name="lucide:map-pin" />
    </span>
    <div class="pickup-card__body">
      <h2>{t('contact.pickupTitle')}</h2>
      <p>{t('contact.pickupBody')}</p>
    </div>
  </section>

  <SocialLinks locale={locale} />
</BaseLayout>
