---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TourCard from '@/components/TourCard.astro';
import { getTours } from '@/lib/tours';
import { useTranslations, type Locale } from '@/i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const tours = await getTours(locale);
---

<BaseLayout title={t('tours.seoTitle')} description={t('tours.seoDescription')} locale={locale}>
  <section style="margin-top: 1rem;">
    <div class="section-head">
      <div>
        <p class="kicker" style="margin: 0;">{t('tours.kicker')}</p>
        <h1 style="margin: 0.4rem 0 0;">{t('tours.heading')}</h1>
      </div>
    </div>

    <div class="tour-grid">
      {tours.map((tour) => <TourCard tour={tour} locale={locale} />)}
    </div>
  </section>
</BaseLayout>
