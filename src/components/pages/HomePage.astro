---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SocialSection from '@/components/SocialSection.astro';
import { getTours, tourSlug } from '@/lib/tours';
import { localizedPath, tourPath, useTranslations, type Locale } from '@/i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const tours = await getTours(locale);
const featuredTour = tours[0];

const galleryImages = [
  '/images/tours/amalfi/Amalfi-italia-moto-excursions-01.jpg',
  '/images/tours/vesuvius/IMG_5828.jpg',
  '/images/tours/napoli/Naples-italia-moto-excursions-03.jpg',
  '/images/tours/amalfi/Amalfi-italia-moto-excursions-04.jpg',
  '/images/tours/vesuvius/IMG_6376.jpg',
  '/images/tours/napoli/Naples-italia-moto-excursions-05.jpg',
  '/images/tours/amalfi/Amalfi-italia-moto-excursions-06.jpg',
  '/images/tours/vesuvius/IMG_6399.jpg',
  '/images/tours/napoli/Naples-italia-moto-excursions-07.jpg',
  '/images/tours/amalfi/Amalfi-italia-moto-excursions-08.jpg',
  '/images/tours/vesuvius/IMG_9646.jpg',
  '/images/tours/napoli/Naples-italia-moto-excursions-09.jpg',
];
---

<BaseLayout
  title={t('site.title')}
  description={t('site.description')}
  image={featuredTour?.data.coverImage}
  isHome={true}
  locale={locale}
>
  <!-- ═══ Hero ═══ -->
  <section class="hero-cinematic">
    <div class="hero-cinematic__bg">
      <video
        class="hero-cinematic__video"
        poster="/video/sito-poster.jpg"
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        aria-hidden="true"
      >
        <source src="/video/sito-mobile.webm" type="video/webm" media="(max-width: 767px)" />
        <source src="/video/sito-mobile.mp4" type="video/mp4" media="(max-width: 767px)" />
        <source src="/video/sito-desktop.webm" type="video/webm" />
        <source src="/video/sito-desktop.mp4" type="video/mp4" />
      </video>
      <div class="hero-cinematic__overlay"></div>
      <div class="hero-cinematic__grain"></div>
    </div>

    <div class="hero-cinematic__content site-shell">
      <div class="hero-cinematic__left">
        <span class="hero-cinematic__kicker">{t('hero.kicker')}</span>
        <h1 class="hero-cinematic__title">
          {t('hero.titlePrefix')} <em>{t('hero.titleEm')}</em> {t('hero.titleSuffix')}
        </h1>
        <p class="hero-cinematic__subtitle">{t('hero.subtitle')}</p>
        <div class="hero-cinematic__cta">
          <a class="btn-solid" href={localizedPath('/contact/', locale)}>{t('hero.ctaBook')}</a>
          <a class="btn-ghost" href={localizedPath('/tours/', locale)}>
            {t('hero.ctaExplore')}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:18px;height:18px;"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>

      <div class="hero-cinematic__right">
        <div class="hero-cinematic__card">
          <img src="/images/motoexcursions-it-dima2.webp" alt={t('hero.cardName')} loading="eager" decoding="async" />
          <div class="hero-cinematic__card-info">
            <strong>{t('hero.cardName')}</strong>
            <span>{t('hero.cardRole')}</span>
          </div>
          <a class="hero-cinematic__card-ig" href="https://www.instagram.com/italia_moto_excursions/" target="_blank" rel="noopener noreferrer" aria-label={t('hero.cardFollow')}>
            <svg viewBox="0 0 24 24" fill="currentColor" style="width:16px;height:16px;"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
          </a>
        </div>
        <div class="hero-cinematic__stats">
          <div class="hero-cinematic__stat">
            <strong>3</strong>
            <span>{t('hero.statRoutes')}</span>
          </div>
          <div class="hero-cinematic__stat-divider"></div>
          <div class="hero-cinematic__stat">
            <strong>500+</strong>
            <span>{t('hero.statRiders')}</span>
          </div>
          <div class="hero-cinematic__stat-divider"></div>
          <div class="hero-cinematic__stat">
            <strong>5.0</strong>
            <span>{t('hero.statRating')}</span>
          </div>
        </div>
      </div>
    </div>

    <div class="hero-cinematic__scroll">
      <div class="hero-cinematic__scroll-line"></div>
    </div>
  </section>

  <!-- ═══ YouTube Intro / About Dima ═══ -->
  <section class="intro-section">
    <div class="intro-video">
      <iframe
        src="https://www.youtube.com/embed/uF6Up6p3y9Q"
        title={t('intro.videoTitle')}
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
        loading="lazy"
      ></iframe>
    </div>
    <div class="intro-text">
      <h2>{t('intro.heading')}</h2>
      <p>{t('intro.p1')}</p>
      <p>{t('intro.p2')}</p>
      <blockquote class="intro-quote">
        {t('intro.quote')}
        <cite>{t('intro.quoteAuthor')}</cite>
      </blockquote>
    </div>
  </section>

  <!-- ═══ Destinations ═══ -->
  <section class="destinations-section">
    <h2>
      {t('destinations.headingPrefix')} <em>{t('destinations.headingEm')}</em> {t('destinations.headingSuffix')}
    </h2>
    <p>{t('destinations.subtitle')}</p>
    <div class="destination-cards">
      {tours.map((tour, i) => (
        <a class="dest-card reveal" data-reveal data-delay={(i % 3) + 1} href={tourPath(tourSlug(tour), locale)}>
          <img src={tour.data.coverImage} alt={tour.data.title} loading="lazy" decoding="async" />
          <div class="dest-card-overlay">
            <span class="dest-stat">{tour.data.duration}</span>
            <h3>{tour.data.title}</h3>
            <span class="dest-subtitle">{tour.data.excerpt}</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- ═══ Excursion Types ═══ -->
  <section class="excursion-types">
    <h2>{t('excursionTypes.heading')}</h2>
    <div class="excursion-cards">
      <div class="exc-card reveal" data-reveal data-delay="1">
        <img src="/images/tours/vesuvius/IMG_4900.jpg" alt={t('excursionTypes.motoTitle')} loading="lazy" decoding="async" />
        <div class="exc-card-body">
          <h3>{t('excursionTypes.motoTitle')}</h3>
          <p>{t('excursionTypes.motoText')}</p>
        </div>
      </div>
      <div class="exc-card reveal" data-reveal data-delay="2">
        <img src="/images/tours/amalfi/Amalfi-italia-moto-excursions-02.jpg" alt={t('excursionTypes.boatTitle')} loading="lazy" decoding="async" />
        <div class="exc-card-body">
          <h3>{t('excursionTypes.boatTitle')}</h3>
          <p>{t('excursionTypes.boatText')}</p>
        </div>
      </div>
      <div class="exc-card reveal" data-reveal data-delay="3">
        <img src="/images/tours/napoli/Naples-italia-moto-excursions-01.jpg" alt={t('excursionTypes.walkTitle')} loading="lazy" decoding="async" />
        <div class="exc-card-body">
          <h3>{t('excursionTypes.walkTitle')}</h3>
          <p>{t('excursionTypes.walkText')}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ Photo Gallery Strip ═══ -->
  <section class="photo-strip">
    <div class="photo-grid-flow">
      {galleryImages.map((src, i) => (
        <button
          class:list={[{ 'span-2': i === 0 || i === 5, 'tall': i === 3 || i === 7 }]}
          data-lightbox-trigger
          data-src={src}
          type="button"
          aria-label={`${t('gallery.viewAlt')} ${i + 1}`}
        >
          <img src={src} alt={`${t('gallery.photoAlt')} ${i + 1}`} loading="lazy" decoding="async" />
        </button>
      ))}
    </div>
  </section>

  <!-- ═══ Social Feed ═══ -->
  <section style="margin-top: 2rem; padding-bottom: 2rem;">
    <div class="section-head">
      <div>
        <p class="kicker" style="margin: 0;">{t('social.kicker')}</p>
        <h2>{t('social.heading')}</h2>
      </div>
      <small id="feed-fetched-at" style="color: var(--muted);"></small>
    </div>

    <div class="surface-card" style="padding: 0.85rem; margin-bottom: 1rem;" data-locale={locale}>
      <div class="section-head" style="margin-bottom: 0.5rem;">
        <h2 style="font-size: 1.2rem;">{t('social.latest')}</h2>
      </div>
      <div class="social-row" data-social-row="latest">
        <p data-social-empty style="margin: 0; color: var(--muted);">{t('social.loading')}</p>
      </div>
    </div>

    <div class="feed-columns">
      <SocialSection
        title="Instagram"
        source="instagram"
        viewMoreUrl="https://www.instagram.com/italia_moto_excursions/"
        items={[]}
        locale={locale}
      />
      <SocialSection
        title="Facebook"
        source="facebook"
        viewMoreUrl="https://www.facebook.com/motodetki"
        items={[]}
        locale={locale}
      />
      <SocialSection
        title="YouTube"
        source="youtube"
        viewMoreUrl="https://www.youtube.com/@Italia_moto_excursions/videos"
        items={[]}
        locale={locale}
      />
    </div>
  </section>

  <!-- Lightbox -->
  <div class="lightbox" id="gallery-lightbox" aria-hidden="true">
    <img src="" alt="" />
    <button aria-label="×">&times;</button>
  </div>
</BaseLayout>

<script is:inline define:vars={{ dateLocaleValue: locale === 'ua' ? 'uk-UA' : locale === 'it' ? 'it-IT' : 'en-US', emptyLabel: t('social.empty'), updatedLabel: t('social.updated') }}>
  // @ts-nocheck
  const LIMIT = 8;

  const escapeHtml = (value) =>
    String(value)
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#039;');

  const trim = (value, max = 140) => {
    if (!value) return '';
    const stringValue = String(value).trim();
    return stringValue.length <= max ? stringValue : `${stringValue.slice(0, max - 1).trim()}…`;
  };

  const iconBySource = {
    instagram: 'IG',
    facebook: 'FB',
    youtube: 'YT',
  };

  const renderCard = (item) => {
    const title = trim(item.title, 90) || `${iconBySource[item.source] ?? 'Post'} update`;
    const text = trim(item.text, 140);
    const image = item.image || item.thumbnail;
    const date = new Date(item.date).toLocaleDateString(dateLocaleValue);

    return `
      <a class="social-card surface-card" href="${escapeHtml(item.url)}" target="_blank" rel="noopener noreferrer">
        ${image ? `<img class="social-thumb" src="${escapeHtml(image)}" alt="${escapeHtml(title)}" loading="lazy" decoding="async" />` : ''}
        <div class="social-content">
          <strong style="display:block;">${escapeHtml(title)}</strong>
          <small style="color: var(--muted);">${escapeHtml(date)} · ${escapeHtml(iconBySource[item.source] ?? item.source)}</small>
          ${text ? `<p>${escapeHtml(text)}</p>` : ''}
        </div>
      </a>
    `;
  };

  const fillRow = (source, items) => {
    const row = document.querySelector(`[data-social-row="${source}"]`);
    if (!row) return;

    if (!items || items.length === 0) {
      row.innerHTML = `<p data-social-empty style="margin:0; color: var(--muted);">${escapeHtml(emptyLabel)}</p>`;
      return;
    }

    row.innerHTML = items.slice(0, LIMIT).map(renderCard).join('');
  };

  const run = async () => {
    try {
      const response = await fetch(`/api/social-feed?limit=${LIMIT}`);
      if (!response.ok) throw new Error('social-feed endpoint is unavailable');
      const payload = await response.json();

      fillRow('instagram', payload.instagram);
      fillRow('facebook', payload.facebook);
      fillRow('youtube', payload.youtube);

      const latest = [...(payload.instagram ?? []), ...(payload.facebook ?? []), ...(payload.youtube ?? [])]
        .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())
        .slice(0, LIMIT);

      fillRow('latest', latest);

      const fetchedAt = document.getElementById('feed-fetched-at');
      if (fetchedAt && payload.fetchedAt) {
        fetchedAt.textContent = `${updatedLabel} ${new Date(payload.fetchedAt).toLocaleString(dateLocaleValue)}`;
      }
    } catch (error) {
      fillRow('instagram', []);
      fillRow('facebook', []);
      fillRow('youtube', []);
      fillRow('latest', []);
    }
  };

  run();

  // Lightbox for photo gallery
  const lightbox = document.getElementById('gallery-lightbox');
  const lightboxImg = lightbox?.querySelector('img');
  const lightboxClose = lightbox?.querySelector('button');

  document.querySelectorAll('[data-lightbox-trigger]').forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const src = trigger.getAttribute('data-src');
      if (lightboxImg && src) {
        lightboxImg.src = src;
        lightboxImg.alt = trigger.getAttribute('aria-label') ?? '';
      }
      lightbox?.classList.add('active');
      lightbox?.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    });
  });

  function closeLightbox() {
    lightbox?.classList.remove('active');
    lightbox?.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  lightboxClose?.addEventListener('click', closeLightbox);
  lightbox?.addEventListener('click', (e) => {
    if (e.target === lightbox) closeLightbox();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && lightbox?.classList.contains('active')) closeLightbox();
  });
</script>
