---
import { Icon } from 'astro-icon/components';
import BaseLayout from '@/layouts/BaseLayout.astro';
import SocialLinks from '@/components/SocialLinks.astro';
import { getTours, tourSlug } from '@/lib/tours';
import { htmlLang, localizedPath, tourPath, useTranslations, type Locale } from '@/i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const tours = await getTours(locale);
const featuredTour = tours[0];

const site = Astro.site ?? new URL('https://motoexcursions.it');
const homeUrl = new URL(localizedPath('/', locale), site).toString();
const orgId = `${site.toString()}#organization`;

// Aggregate rating across all tour reviews — feeds Home aggregate signal
const reviewFiles = import.meta.glob('../../content/tours/*.reviews.json', { eager: true }) as Record<string, { default?: Array<{ rating: number }> }>;
const allReviews = Object.values(reviewFiles).flatMap((m) => m.default ?? []);
const reviewCount = allReviews.length;
const aggRating = reviewCount
  ? (allReviews.reduce((s, r) => s + r.rating, 0) / reviewCount).toFixed(1)
  : '5.0';

const breadcrumbs = [
  { name: t('nav.home'), url: localizedPath('/', locale) },
];

const webPageLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': `${homeUrl}#webpage`,
  url: homeUrl,
  name: t('site.title'),
  description: t('site.description'),
  inLanguage: htmlLang[locale],
  isPartOf: { '@id': `${site.toString()}#website` },
  about: { '@id': orgId },
  primaryImageOfPage: featuredTour?.data.coverImage
    ? new URL(featuredTour.data.coverImage, site).toString()
    : undefined,
};

const offerCatalogLd = {
  '@context': 'https://schema.org',
  '@type': 'OfferCatalog',
  name: t('tours.heading'),
  inLanguage: htmlLang[locale],
  provider: { '@id': orgId },
  itemListElement: tours.map((tour) => ({
    '@type': 'Offer',
    name: tour.data.title,
    description: tour.data.excerpt,
    price: tour.data.priceFrom,
    priceCurrency: 'EUR',
    availability: 'https://schema.org/InStock',
    url: new URL(tourPath(tourSlug(tour), locale), site).toString(),
    image: new URL(tour.data.coverImage, site).toString(),
    itemOffered: {
      '@type': 'TouristTrip',
      name: tour.data.title,
      description: tour.data.excerpt,
      url: new URL(tourPath(tourSlug(tour), locale), site).toString(),
    },
  })),
};

const aggRatingLd = reviewCount
  ? {
      '@context': 'https://schema.org',
      '@type': 'AggregateRating',
      itemReviewed: { '@id': orgId },
      ratingValue: aggRating,
      reviewCount,
      bestRating: 5,
      worstRating: 1,
    }
  : null;

const homeLd = aggRatingLd
  ? [webPageLd, offerCatalogLd, aggRatingLd]
  : [webPageLd, offerCatalogLd];

const galleryImages = [
  '/images/tours/amalfi/italia-moto-excursions-amalfi-tour-00002.webp',
  '/images/tours/vesuvius/motoexcursions-vesuvius-tour-00003.webp',
  '/images/tours/napoli/italia-moto-excursions-napoli-tour-00004.webp',
  '/images/tours/amalfi/italia-moto-excursions-amalfi-tour-00008.webp',
  '/images/tours/vesuvius/motoexcursions-vesuvius-tour-00010.webp',
  '/images/tours/napoli/italia-moto-excursions-napoli-tour-00012.webp',
  '/images/tours/amalfi/italia-moto-excursions-amalfi-tour-00018.webp',
  '/images/tours/vesuvius/motoexcursions-vesuvius-tour-00017.webp',
  '/images/tours/napoli/italia-moto-excursions-napoli-tour-00020.webp',
  '/images/tours/amalfi/italia-moto-excursions-amalfi-tour-00030.webp',
  '/images/tours/vesuvius/motoexcursions-vesuvius-tour-00025.webp',
  '/images/tours/napoli/italia-moto-excursions-napoli-tour-00030.webp',
];
---

<BaseLayout
  title={t('site.title')}
  description={t('site.description')}
  image={featuredTour?.data.coverImage}
  isHome={true}
  locale={locale}
  breadcrumbs={breadcrumbs}
  jsonLd={homeLd}
>
  <!-- ═══ Hero ═══ -->
  <section class="hero-cinematic">
    <div class="hero-cinematic__bg">
      <video
        class="hero-cinematic__video"
        poster="/video/hero-poster.jpg"
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        aria-hidden="true"
      >
        <source src="/video/hero-mobile.mp4" type="video/mp4" media="(max-width: 767px)" />
        <source src="/video/hero-desktop.mp4" type="video/mp4" />
      </video>
      <div class="hero-cinematic__overlay"></div>
      <div class="hero-cinematic__grain"></div>
    </div>

    <div class="hero-cinematic__content site-shell">
      <div class="hero-cinematic__left">
        <span class="hero-cinematic__kicker">{t('hero.kicker')}</span>
        <h1 class="hero-cinematic__title">
          {t('hero.titlePrefix')} <em>{t('hero.titleEm')}</em> {t('hero.titleSuffix')}
        </h1>
        <p class="hero-cinematic__subtitle">{t('hero.subtitle')}</p>
        <div class="hero-cinematic__cta">
          <a class="btn-ghost" href={localizedPath('/tours/', locale)}>
            {t('hero.ctaExplore')}
            <Icon name="lucide:arrow-right" width={18} height={18} />
          </a>
          <a class="btn-solid" href={localizedPath('/contact/', locale)}>{t('hero.ctaBook')}</a>
        </div>
      </div>

      <div class="hero-cinematic__right">
        <div class="hero-cinematic__card">
          <a class="hero-cinematic__card-link" href={localizedPath('/tours/', locale)} aria-label={t('hero.ctaExplore')}>
            <img src="/images/motoexcursions-it-dima2.webp" alt={t('hero.cardName')} loading="eager" decoding="async" />
            <div class="hero-cinematic__card-info">
              <strong>{t('hero.cardName')}</strong>
              <span>{t('hero.cardRole')}</span>
            </div>
          </a>
          <a class="hero-cinematic__card-ig" href="https://www.instagram.com/italia_moto_excursions/" target="_blank" rel="noopener noreferrer" aria-label={t('hero.cardFollow')}>
            <Icon name="lucide:instagram" width={16} height={16} />
          </a>
        </div>
        <div class="hero-cinematic__stats">
          <div class="hero-cinematic__stat">
            <strong>3</strong>
            <span>{t('hero.statRoutes')}</span>
          </div>
          <div class="hero-cinematic__stat-divider"></div>
          <div class="hero-cinematic__stat">
            <strong>500+</strong>
            <span>{t('hero.statRiders')}</span>
          </div>
          <div class="hero-cinematic__stat-divider"></div>
          <div class="hero-cinematic__stat">
            <strong>5.0</strong>
            <span>{t('hero.statRating')}</span>
          </div>
        </div>
      </div>
    </div>

    <div class="hero-cinematic__scroll">
      <div class="hero-cinematic__scroll-line"></div>
    </div>
  </section>

  <!-- ═══ YouTube Intro / About Dima ═══ -->
  <section class="intro-section">
    <div class="intro-video">
      <button
        type="button"
        class="yt-lite"
        data-yt-id="AF9H8nreywo"
        data-yt-title={t('intro.videoTitle')}
        aria-label={t('intro.videoTitle')}
        style="background-image: url('https://i.ytimg.com/vi/AF9H8nreywo/maxresdefault.jpg')"
      >
        <span class="yt-lite__shade" aria-hidden="true"></span>
        <span class="yt-lite__play" aria-hidden="true">
          <svg width="68" height="48" viewBox="0 0 68 48">
            <path d="M66.52 7.74c-.78-2.93-2.49-5.41-5.42-6.19C55.79.13 34 0 34 0S12.21.13 6.9 1.55C3.97 2.33 2.27 4.81 1.48 7.74 0 13.05 0 24 0 24s0 10.95 1.48 16.26c.78 2.93 2.49 5.41 5.42 6.19C12.21 47.87 34 48 34 48s21.79-.13 27.1-1.55c2.93-.78 4.64-3.26 5.42-6.19C68 34.95 68 24 68 24s0-10.95-1.48-16.26z" fill="#f00"/>
            <path d="M45 24 27 14v20" fill="#fff"/>
          </svg>
        </span>
      </button>
    </div>
    <div class="intro-text">
      <h2>{t('intro.heading')}</h2>
      <p>{t('intro.p1')}</p>
      <p>{t('intro.p2')}</p>
      <blockquote class="intro-quote">
        {t('intro.quote')}
        <cite>{t('intro.quoteAuthor')}</cite>
      </blockquote>
    </div>
  </section>

  <!-- ═══ Destinations ═══ -->
  <section class="destinations-section">
    <h2>
      {t('destinations.headingPrefix')} <em>{t('destinations.headingEm')}</em> {t('destinations.headingSuffix')}
    </h2>
    <p>{t('destinations.subtitle')}</p>
    <div class="destination-cards">
      {tours.map((tour, i) => (
        <a class="dest-card reveal" data-reveal data-delay={(i % 3) + 1} href={tourPath(tourSlug(tour), locale)}>
          <img src={tour.data.coverImage} alt={tour.data.title} loading="lazy" decoding="async" />
          <div class="dest-card-overlay">
            <span class="dest-stat">{tour.data.duration}</span>
            <h3>{tour.data.title}</h3>
            <span class="dest-subtitle">{tour.data.excerpt}</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- ═══ Excursion Types ═══ -->
  <section class="excursion-types">
    <h2>{t('excursionTypes.heading')}</h2>
    <div class="excursion-cards">
      <div class="exc-card reveal" data-reveal data-delay="1">
        <img src="/images/tours/vesuvius/motoexcursions-vesuvius-tour-00001.webp" alt={t('excursionTypes.motoTitle')} loading="lazy" decoding="async" />
        <div class="exc-card-body">
          <h3>{t('excursionTypes.motoTitle')}</h3>
          <p>{t('excursionTypes.motoText')}</p>
        </div>
      </div>
      <div class="exc-card reveal" data-reveal data-delay="2">
        <img src="/images/tours/napoli/italia-moto-excursions-napoli-tour-00015.webp" alt={t('excursionTypes.boatTitle')} loading="lazy" decoding="async" />
        <div class="exc-card-body">
          <h3>{t('excursionTypes.boatTitle')}</h3>
          <p>{t('excursionTypes.boatText')}</p>
        </div>
      </div>
      <div class="exc-card reveal" data-reveal data-delay="3">
        <img src="/images/tours/napoli/italia-moto-excursions-napoli-tour-00001.webp" alt={t('excursionTypes.walkTitle')} loading="lazy" decoding="async" />
        <div class="exc-card-body">
          <h3>{t('excursionTypes.walkTitle')}</h3>
          <p>{t('excursionTypes.walkText')}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ Photo Gallery Strip ═══ -->
  <section class="photo-strip">
    <div class="photo-grid-flow">
      {galleryImages.map((src, i) => (
        <button
          class:list={[{ 'span-2': i === 0 || i === 5, 'tall': i === 3 || i === 7 }]}
          data-lightbox-trigger
          data-src={src}
          type="button"
          aria-label={`${t('gallery.viewAlt')} ${i + 1}`}
        >
          <img src={src} alt={`${t('gallery.photoAlt')} ${i + 1}`} loading="lazy" decoding="async" />
        </button>
      ))}
    </div>
  </section>

  <!-- ═══ Social Links ═══ -->
  <SocialLinks locale={locale} />

  <!-- Lightbox -->
  <div class="lightbox" id="gallery-lightbox" aria-hidden="true">
    <img src="" alt="" />
    <button aria-label="×">&times;</button>
  </div>

  <!-- Cinema-mode YouTube dialog -->
  <dialog class="yt-cinema" id="yt-cinema" aria-label="Video player">
    <div class="yt-cinema__frame">
      <div class="yt-cinema__embed" data-yt-embed></div>
      <button type="button" class="yt-cinema__close" data-yt-close aria-label="Close video">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
  </dialog>
</BaseLayout>

<script is:inline>
  // Lightbox for photo gallery
  const lightbox = document.getElementById('gallery-lightbox');
  const lightboxImg = lightbox?.querySelector('img');
  const lightboxClose = lightbox?.querySelector('button');

  document.querySelectorAll('[data-lightbox-trigger]').forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const src = trigger.getAttribute('data-src');
      if (lightboxImg && src) {
        lightboxImg.src = src;
        lightboxImg.alt = trigger.getAttribute('aria-label') ?? '';
      }
      lightbox?.classList.add('active');
      lightbox?.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    });
  });

  function closeLightbox() {
    lightbox?.classList.remove('active');
    lightbox?.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  lightboxClose?.addEventListener('click', closeLightbox);
  lightbox?.addEventListener('click', (e) => {
    if (e.target === lightbox) closeLightbox();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && lightbox?.classList.contains('active')) closeLightbox();
  });

  // Cinema-mode YouTube: open <dialog> with iframe on poster click
  const ytCinema = document.getElementById('yt-cinema');
  const ytEmbed = ytCinema?.querySelector('[data-yt-embed]');
  const ytClose = ytCinema?.querySelector('[data-yt-close]');

  function openCinema(id, title) {
    if (!ytCinema || !ytEmbed) return;
    ytEmbed.innerHTML = '';
    const iframe = document.createElement('iframe');
    iframe.setAttribute('src', `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&rel=0&modestbranding=1`);
    iframe.setAttribute('title', title);
    iframe.setAttribute('allow', 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture');
    iframe.setAttribute('allowfullscreen', '');
    ytEmbed.appendChild(iframe);
    ytCinema.showModal();
    document.body.style.overflow = 'hidden';
    requestAnimationFrame(() => ytCinema.classList.add('is-open'));
  }

  function closeCinema() {
    if (!ytCinema) return;
    ytCinema.classList.remove('is-open');
    setTimeout(() => {
      ytCinema.close();
      if (ytEmbed) ytEmbed.innerHTML = '';
      document.body.style.overflow = '';
    }, 220);
  }

  document.querySelectorAll('.yt-lite').forEach((btn) => {
    btn.addEventListener('click', () => {
      const id = btn.getAttribute('data-yt-id');
      const title = btn.getAttribute('data-yt-title') || 'Video';
      if (id) openCinema(id, title);
    });
  });

  ytClose?.addEventListener('click', closeCinema);
  ytCinema?.addEventListener('cancel', (e) => {
    e.preventDefault();
    closeCinema();
  });
  ytCinema?.addEventListener('click', (e) => {
    if (e.target === ytCinema) closeCinema();
  });
</script>
