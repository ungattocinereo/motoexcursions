---
import { Icon } from 'astro-icon/components';
import { useTranslations, dateLocale, type Locale } from '@/i18n/utils';

interface TourOption {
  slug: string;
  title: string;
}

interface Props {
  locale: Locale;
  pageUrl: string;
  /** List of tours for the dropdown. Omit (or leave empty) when `preselectedTourTitle` is used. */
  tours?: TourOption[];
  /** If set, the tour is fixed (no dropdown) — used on tour detail pages. */
  preselectedTourTitle?: string;
}

const { locale, tours, preselectedTourTitle } = Astro.props;
const t = useTranslations(locale);

const waPhone = '393347200808';
const showDropdown = !preselectedTourTitle && Array.isArray(tours) && tours.length > 0;
---

<form
  class="lead-form surface-card wa-form"
  data-wa-form
  data-wa-phone={waPhone}
  data-wa-greeting-book={t('form.waGreetingBook')}
  data-wa-greeting-general={t('form.waGreetingGeneral')}
  data-wa-label-tour={t('form.waTour')}
  data-wa-label-date={t('form.waDate')}
  data-wa-label-note={t('form.waNote')}
  data-wa-preselected={preselectedTourTitle ?? ''}
  data-wa-sent-from={t('form.sentFrom')}
  data-wa-locale={locale}
  style="padding: 1rem;"
>
  {showDropdown && (
    <label>
      {t('form.tour')}
      <select name="tour" data-wa-tour>
        <option value="">{t('form.chooseTour')}</option>
        {tours!.map((tour) => (
          <option value={tour.title}>{tour.title}</option>
        ))}
        <option value="__custom__">{t('form.tourCustom')}</option>
      </select>
    </label>
  )}

  <label>
    {t('form.date')}
    <input type="date" name="date" lang={dateLocale[locale]} data-wa-date />
  </label>

  <label>
    {t('form.note')}
    <input
      type="text"
      name="note"
      data-wa-note
      placeholder={t('form.notePlaceholder')}
      maxlength="240"
      autocomplete="off"
    />
  </label>

  <button type="submit" class="wa-form__submit">
    <Icon name="lucide:message-circle" aria-hidden="true" />
    <span>{t('form.openWhatsApp')}</span>
  </button>
</form>

<script>
  // @ts-nocheck
  const forms = document.querySelectorAll('[data-wa-form]');

  const formatDate = (iso, locale) => {
    if (!iso) return '';
    try {
      const d = new Date(iso + 'T00:00:00');
      if (Number.isNaN(d.getTime())) return iso;
      const map = { en: 'en-GB', it: 'it-IT', ua: 'uk-UA', ru: 'ru-RU' };
      return d.toLocaleDateString(map[locale] || 'en-GB', {
        day: 'numeric',
        month: 'long',
        year: 'numeric',
      });
    } catch {
      return iso;
    }
  };

  forms.forEach((form) => {
    form.addEventListener('submit', (event) => {
      event.preventDefault();

      const phone = form.dataset.waPhone;
      const greetingBook = form.dataset.waGreetingBook;
      const greetingGeneral = form.dataset.waGreetingGeneral;
      const labelTour = form.dataset.waLabelTour;
      const labelDate = form.dataset.waLabelDate;
      const labelNote = form.dataset.waLabelNote;
      const sentFrom = form.dataset.waSentFrom;
      const preselected = form.dataset.waPreselected || '';
      const locale = form.dataset.waLocale || 'en';

      const tourField = form.querySelector('[data-wa-tour]');
      const dateField = form.querySelector('[data-wa-date]');
      const noteField = form.querySelector('[data-wa-note]');

      const rawTour = tourField ? tourField.value : '';
      const tour = preselected || (rawTour && rawTour !== '__custom__' ? rawTour : '');
      const date = dateField ? dateField.value : '';
      const note = noteField ? noteField.value.trim() : '';

      const lines = [];
      lines.push(tour ? greetingBook : greetingGeneral);
      if (tour) lines.push(`${labelTour}: ${tour}`);
      if (date) lines.push(`${labelDate}: ${formatDate(date, locale)}`);
      if (note) lines.push(`${labelNote}: ${note}`);
      lines.push('');
      lines.push(`${sentFrom} ${window.location.host}`);

      const text = lines.join('\n');
      const url = `https://wa.me/${phone}?text=${encodeURIComponent(text)}`;

      window.open(url, '_blank', 'noopener,noreferrer');
    });
  });
</script>
