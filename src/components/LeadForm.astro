---
import { useTranslations, dateLocale, type Locale } from '@/i18n/utils';

interface Props {
  tourSlug: string;
  tourTitle: string;
  pageUrl: string;
  locale: Locale;
  buttonLabel?: string;
  showHeading?: boolean;
}

const { tourSlug, tourTitle, pageUrl, locale, buttonLabel, showHeading = true } = Astro.props;
const t = useTranslations(locale);
const submitLabel = buttonLabel ?? t('form.submit');
---

<form
  class="lead-form surface-card"
  data-lead-form
  data-locale={locale}
  data-label-sending={t('form.sending')}
  data-label-success={t('form.success')}
  data-label-error={t('form.error')}
  style="padding: 1rem;"
>
  {showHeading ? (
    <div class="section-head" style="margin-bottom: 0.5rem;">
      <h2 style="font-size: 1.3rem;">{t('form.title')}</h2>
    </div>
  ) : null}
  <label>
    {t('form.name')} *
    <input name="name" autocomplete="name" required />
  </label>
  <label>
    {t('form.contact')} *
    <input name="contact" autocomplete="tel" required />
  </label>
  <label>
    {t('form.date')}
    <input type="date" name="date" lang={dateLocale[locale]} />
  </label>
  <label>
    {t('form.message')}
    <textarea name="message" placeholder={t('form.messagePlaceholder')}></textarea>
  </label>

  <input name="tourSlug" type="hidden" value={tourSlug} />
  <input name="tourTitle" type="hidden" value={tourTitle} />
  <input name="pageUrl" type="hidden" value={pageUrl} />
  <input name="locale" type="hidden" value={locale} />
  <input
    name="honeypot"
    type="text"
    autocomplete="off"
    tabindex="-1"
    aria-hidden="true"
    style="position: absolute; left: -99999px; opacity: 0; width: 1px; height: 1px;"
  />

  <button type="submit">{submitLabel}</button>
  <p data-lead-status style="margin: 0; color: var(--muted);"></p>
</form>

<script>
  // @ts-nocheck
  const forms = /** @type {NodeListOf<HTMLFormElement>} */ (document.querySelectorAll('[data-lead-form]'));

  forms.forEach((form) => {
    const status = /** @type {HTMLElement | null} */ (form.querySelector('[data-lead-status]'));
    const submitButton = /** @type {HTMLButtonElement | null} */ (form.querySelector('button[type="submit"]'));
    const originalButtonText = submitButton?.textContent ?? '';
    const sendingLabel = form.dataset.labelSending ?? 'Sending...';
    const successLabel = form.dataset.labelSuccess ?? 'Thank you.';
    const errorLabel = form.dataset.labelError ?? 'Could not send request.';

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      const formData = new FormData(form);
      const payload = Object.fromEntries(formData.entries());

      if (submitButton) {
        submitButton.disabled = true;
        submitButton.textContent = sendingLabel;
      }
      if (status) status.textContent = '';

      try {
        const response = await fetch('/api/lead', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(payload),
        });

        const result = await response.json().catch(() => ({}));

        if (!response.ok) {
          throw new Error(result?.error ?? errorLabel);
        }

        if (status) status.textContent = successLabel;
        form.reset();
      } catch (error) {
        if (status) status.textContent = error instanceof Error ? error.message : errorLabel;
      } finally {
        if (submitButton) {
          submitButton.disabled = false;
          submitButton.textContent = originalButtonText;
        }
      }
    });
  });
</script>
