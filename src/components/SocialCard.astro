---
import type { FeedItem } from '../lib/social/types';

interface Props {
  item: FeedItem;
}

const { item } = Astro.props;
const label = item.title ?? item.text ?? 'Open post';
---

<a class="social-card surface-card" href={item.url} target="_blank" rel="noopener noreferrer" aria-label={label}>
  {
    item.image || item.thumbnail ? (
      <img class="social-thumb" src={item.image ?? item.thumbnail ?? ''} alt={label} loading="lazy" decoding="async" />
    ) : null
  }
  <div class="social-content">
    <strong style="display: block;">{item.title ?? item.source.toUpperCase()}</strong>
    <small style="color: var(--muted);">{new Date(item.date).toLocaleDateString('en-US')}</small>
    {item.text ? <p>{item.text}</p> : null}
  </div>
</a>
