---
import { useTranslations, type Locale } from '@/i18n/utils';

interface Props {
  images: string[];
  title: string;
  galleryId?: string;
  locale: Locale;
  heading?: string;
}

const { images, title, galleryId, locale, heading } = Astro.props;
const t = useTranslations(locale);
const safeId = `gallery-${(galleryId ?? title).toLowerCase().replace(/[^a-z0-9]+/g, '-')}`;
const headingText = heading ?? 'Gallery';
---

<section id={safeId} data-gallery-root>
  <div class="section-head" style="margin: 1.4rem 0 0.8rem;">
    <h2 style="font-size: 1.3rem;">{headingText}</h2>
  </div>
  <div class="gallery-grid">
    {images.map((image, index) => (
      <button type="button" data-gallery-image={image} aria-label={`${t('gallery.viewAlt')} ${index + 1} / ${title}`}>
        <img src={image} alt={`${title} — ${index + 1}`} loading="lazy" decoding="async" />
      </button>
    ))}
  </div>
  <div class="lightbox" data-gallery-lightbox>
    <button type="button" data-gallery-close aria-label="×">×</button>
    <img src="" alt={title} data-gallery-expanded />
  </div>
</section>

<script is:inline define:vars={{ safeId }}>
  const root = document.getElementById(safeId);

  if (root) {
    const lightbox = root.querySelector('[data-gallery-lightbox]');
    const expanded = root.querySelector('[data-gallery-expanded]');
    const closeBtn = root.querySelector('[data-gallery-close]');
    const triggers = root.querySelectorAll('[data-gallery-image]');

    const close = () => {
      lightbox?.classList.remove('active');
      document.body.style.overflow = '';
    };

    triggers.forEach((trigger) => {
      trigger.addEventListener('click', () => {
        const src = trigger.getAttribute('data-gallery-image');
        if (!src || !expanded || !lightbox) return;
        expanded.setAttribute('src', src);
        lightbox.classList.add('active');
        document.body.style.overflow = 'hidden';
      });
    });

    closeBtn?.addEventListener('click', close);
    lightbox?.addEventListener('click', (event) => {
      if (event.target === lightbox) close();
    });
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') close();
    });
  }
</script>
