---
import { useTranslations, type Locale } from '@/i18n/utils';

interface Props {
  images: string[];
  title: string;
  galleryId?: string;
  locale: Locale;
  /** Number of items shown before "Show all N photos" CTA. */
  initialCount?: number;
  heading?: string;
}

const { images, title, galleryId, locale, initialCount = 18, heading } = Astro.props;
const t = useTranslations(locale);

const safeId = `gallery-${(galleryId ?? title).toLowerCase().replace(/[^a-z0-9]+/g, '-')}`;
const headingText = heading ?? 'Gallery';
const showHeading = headingText.trim().length > 0;

const total = images.length;
const showToggle = total > initialCount;

const showAllLabel = t('gallery.showAll').replace('{count}', String(total));
const showLessLabel = t('gallery.showLess');
const prevLabel = t('gallery.prev');
const nextLabel = t('gallery.next');
const closeLabel = t('gallery.close');
---

<section id={safeId} class="gallery" data-gallery-root data-initial-count={initialCount}>
  {(showHeading || total > 0) && (
    <div class="gallery__head">
      {showHeading && <h2>{headingText}</h2>}
      {total > 0 && (
        <span class="gallery__count" aria-label={`${total} photos`}>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="2"></rect>
            <circle cx="8.5" cy="8.5" r="1.5"></circle>
            <path d="M21 15l-5-5L5 21"></path>
          </svg>
          <strong>{total}</strong>
        </span>
      )}
    </div>
  )}

  <div class="gallery__grid">
    {images.map((src, index) => {
      const isHidden = showToggle && index >= initialCount;
      return (
        <button
          type="button"
          class="gallery__tile"
          data-gallery-image={src}
          data-gallery-index={index}
          data-hidden={isHidden ? 'true' : undefined}
          aria-label={`${t('gallery.viewAlt')} ${index + 1} / ${total}`}
        >
          <img
            src={src}
            alt={`${title} — ${index + 1}`}
            loading={index < 12 ? 'eager' : 'lazy'}
            decoding="async"
          />
        </button>
      );
    })}
  </div>

  {showToggle && (
    <div class="gallery__toggle-wrap">
      <button type="button" class="gallery__toggle" data-gallery-toggle
        data-label-more={showAllLabel}
        data-label-less={showLessLabel}>
        <span>{showAllLabel}</span>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M6 9l6 6 6-6"></path>
        </svg>
      </button>
    </div>
  )}

  <!-- Lightbox -->
  <dialog class="gallery-lightbox" data-gallery-lightbox aria-label={title}>
    <button type="button" class="gallery-lightbox__close" data-gallery-close aria-label={closeLabel}>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M18 6L6 18M6 6l12 12"></path>
      </svg>
    </button>

    <button type="button" class="gallery-lightbox__nav gallery-lightbox__nav--prev" data-gallery-prev aria-label={prevLabel}>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M15 18l-6-6 6-6"></path>
      </svg>
    </button>

    <div class="gallery-lightbox__stage">
      <img class="gallery-lightbox__img" data-gallery-expanded src="" alt={title} />
    </div>

    <div class="gallery-lightbox__footer">
      <span class="gallery-lightbox__counter" data-gallery-caption>1 / {total}</span>
    </div>

    <button type="button" class="gallery-lightbox__nav gallery-lightbox__nav--next" data-gallery-next aria-label={nextLabel}>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M9 6l6 6-6 6"></path>
      </svg>
    </button>
  </dialog>
</section>

<script is:inline define:vars={{ safeId, counterTemplate: t('gallery.counter') }}>
  const root = document.getElementById(safeId);
  if (root) {
    const tiles = Array.from(root.querySelectorAll('[data-gallery-image]'));
    const sources = tiles.map((el) => el.getAttribute('data-gallery-image') || '');
    const lightbox = root.querySelector('[data-gallery-lightbox]');
    const img = root.querySelector('[data-gallery-expanded]');
    const caption = root.querySelector('[data-gallery-caption]');
    const closeBtn = root.querySelector('[data-gallery-close]');
    const prevBtn = root.querySelector('[data-gallery-prev]');
    const nextBtn = root.querySelector('[data-gallery-next]');
    const toggleBtn = root.querySelector('[data-gallery-toggle]');
    const stage = root.querySelector('.gallery-lightbox__stage');

    let current = 0;
    let isOpen = false;
    const preloadCache = new Set();

    const preload = (idx) => {
      const src = sources[idx];
      if (!src || preloadCache.has(src)) return;
      const i = new Image();
      i.src = src;
      preloadCache.add(src);
    };

    const setCounter = (i) => {
      if (!caption) return;
      caption.textContent = counterTemplate
        .replace('{current}', String(i + 1))
        .replace('{total}', String(sources.length));
    };

    const show = (idx, direction = 0) => {
      const total = sources.length;
      if (total === 0 || !img) return;
      current = ((idx % total) + total) % total;

      // Crossfade + slight horizontal slide in the direction of travel
      img.classList.add('is-switching');
      if (direction !== 0) {
        img.style.transform = `translateX(${direction * -14}px) scale(0.985)`;
      }

      const applyNew = () => {
        img.setAttribute('src', sources[current]);
        img.setAttribute('alt', `${root.getAttribute('aria-label') || ''} ${current + 1}`);
        // Next frame: animate in
        requestAnimationFrame(() => {
          img.style.transform = '';
          img.classList.remove('is-switching');
        });
      };

      // Short delay so the out-transition is visible
      setTimeout(applyNew, 90);

      setCounter(current);
      preload((current + 1) % total);
      preload((current - 1 + total) % total);
    };

    const open = (idx) => {
      if (!lightbox || !img) return;
      isOpen = true;
      lightbox.showModal();
      document.body.style.overflow = 'hidden';

      // Set image instantly (no crossfade on initial open)
      img.setAttribute('src', sources[idx]);
      current = idx;
      setCounter(current);
      preload((current + 1) % sources.length);
      preload((current - 1 + sources.length) % sources.length);

      // Trigger open animation
      lightbox.classList.remove('is-closing');
      requestAnimationFrame(() => lightbox.classList.add('is-entered'));
    };

    const close = () => {
      if (!lightbox) return;
      isOpen = false;
      lightbox.classList.remove('is-entered');
      lightbox.classList.add('is-closing');
      // Wait for close transition
      setTimeout(() => {
        lightbox.close();
        lightbox.classList.remove('is-closing');
        document.body.style.overflow = '';
      }, 200);
    };

    // Native ESC close fires 'cancel' — intercept to keep fade animation
    lightbox?.addEventListener('cancel', (event) => {
      event.preventDefault();
      close();
    });

    tiles.forEach((tile, idx) => {
      tile.addEventListener('click', () => open(idx));
    });

    closeBtn?.addEventListener('click', (e) => { e.stopPropagation(); close(); });
    prevBtn?.addEventListener('click', (e) => { e.stopPropagation(); show(current - 1, -1); });
    nextBtn?.addEventListener('click', (e) => { e.stopPropagation(); show(current + 1, 1); });

    // Tap / click on image closes
    img?.addEventListener('click', (e) => { e.stopPropagation(); close(); });

    // Click on backdrop closes
    lightbox?.addEventListener('click', (event) => {
      if (event.target === lightbox || event.target === stage) close();
    });

    document.addEventListener('keydown', (event) => {
      if (!isOpen) return;
      if (event.key === 'ArrowRight') show(current + 1, 1);
      else if (event.key === 'ArrowLeft') show(current - 1, -1);
    });

    // Touch swipe (horizontal nav + vertical-down to close)
    let tStartX = 0, tStartY = 0, tStartT = 0, tMoved = false;
    lightbox?.addEventListener('touchstart', (e) => {
      const t = e.changedTouches[0];
      tStartX = t.clientX;
      tStartY = t.clientY;
      tStartT = Date.now();
      tMoved = false;
    }, { passive: true });
    lightbox?.addEventListener('touchmove', (e) => {
      const t = e.changedTouches[0];
      if (Math.abs(t.clientX - tStartX) > 8 || Math.abs(t.clientY - tStartY) > 8) tMoved = true;
    }, { passive: true });
    lightbox?.addEventListener('touchend', (e) => {
      const t = e.changedTouches[0];
      const dx = t.clientX - tStartX;
      const dy = t.clientY - tStartY;
      const absDx = Math.abs(dx);
      const absDy = Math.abs(dy);

      if (!tMoved) return; // pure tap — let the click handler close via image/backdrop

      if (absDx > 50 && absDx > absDy) {
        if (dx < 0) show(current + 1, 1);
        else show(current - 1, -1);
      } else if (dy > 80 && absDy > absDx) {
        close();
      }
    }, { passive: true });

    // Show more / less toggle
    toggleBtn?.addEventListener('click', () => {
      const isExpanded = root.getAttribute('data-expanded') === 'true';
      if (isExpanded) {
        root.removeAttribute('data-expanded');
        const initial = Number(root.getAttribute('data-initial-count') || '18');
        tiles.forEach((tile, idx) => {
          if (idx >= initial) tile.setAttribute('data-hidden', 'true');
        });
        const span = toggleBtn.querySelector('span');
        if (span) span.textContent = toggleBtn.getAttribute('data-label-more') || '';
        toggleBtn.classList.remove('is-expanded');
        root.scrollIntoView({ behavior: 'smooth', block: 'start' });
      } else {
        root.setAttribute('data-expanded', 'true');
        tiles.forEach((tile) => tile.removeAttribute('data-hidden'));
        const span = toggleBtn.querySelector('span');
        if (span) span.textContent = toggleBtn.getAttribute('data-label-less') || '';
        toggleBtn.classList.add('is-expanded');
      }
    });
  }
</script>
