---
import '../styles/global.css';
import LangSwitch from '@/components/LangSwitch.astro';
import { htmlLang, localizedPath, useTranslations, type Locale, locales } from '@/i18n/utils';

interface Props {
  title: string;
  description?: string;
  image?: string;
  noIndex?: boolean;
  isHome?: boolean;
  locale: Locale;
}

const {
  title,
  description,
  image,
  noIndex = false,
  isHome = false,
  locale,
} = Astro.props;

const t = useTranslations(locale);
const finalDescription = description ?? t('site.defaultDescription');

const site = Astro.site ?? new URL('https://motoexcursions.it');
const canonical = new URL(Astro.url.pathname, site).toString();
const ogImage = image ? new URL(image, site).toString() : new URL('/images/tours/vesuvius/IMG_4900.jpg', site).toString();
const currentPath = Astro.url.pathname;

const alternates = locales.map((code) => {
  const hreflang = code === 'ua' ? 'uk' : code;
  const path = localizedPath(currentPath, code);
  return {
    hreflang,
    href: new URL(path, site).toString(),
    code,
  };
});
const xDefault = new URL(localizedPath(currentPath, 'en'), site).toString();

const waHref = `https://wa.me/393347200808?text=${encodeURIComponent(t('wa.prefill'))}`;
---

<!doctype html>
<html lang={htmlLang[locale]}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={finalDescription} />
    <link rel="canonical" href={canonical} />
    {noIndex ? <meta name="robots" content="noindex,nofollow" /> : <meta name="robots" content="index,follow" />}

    {alternates.map((alt) => (
      <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={xDefault} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={finalDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Italia Moto Excursions" />
    <meta property="og:locale" content={locale === 'en' ? 'en_US' : locale === 'it' ? 'it_IT' : 'uk_UA'} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={finalDescription} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/png" href="/images/favicon-152.png" />
  </head>
  <body>
