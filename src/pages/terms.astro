---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Terms | Italia Moto Excursions" description="Basic booking and participation terms.">
  <section class="surface-card" style="margin-top: 1rem; padding: 1rem;">
    <h1 style="margin-top: 0;">Terms</h1>
    <p>Detailed terms will be finalized with the production content update.</p>
    <ul>
      <li>Route and timing may change due to weather, traffic, or safety conditions.</li>
      <li>Guests are expected to provide accurate contact details.</li>
      <li>Cancellation and refund policy will be added in the final legal text.</li>
    </ul>
  </section>
</BaseLayout>
