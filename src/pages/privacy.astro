---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Privacy Policy | Italia Moto Excursions" description="Privacy policy for request forms and communication.">
  <section class="surface-card" style="margin-top: 1rem; padding: 1rem;">
    <h1 style="margin-top: 0;">Privacy Policy</h1>
    <p>
      We collect only the data you send through request forms: name, contact, requested date, and message. This data is
      used only to answer your request and arrange excursions.
    </p>
    <p>
      Form submissions are delivered to our Telegram workspace and are not sold to third parties. Contact us to request
      correction or deletion of your data.
    </p>
    <p>
      Email for privacy requests:
      <a href="mailto:info@motoexcursions.it">info@motoexcursions.it</a>
    </p>
  </section>
</BaseLayout>
